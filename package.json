{
  "name": "oshicardapi",
  "version": "1.0.0",
  "description": "GraphQL API for the hololive Official Card Game",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --env dev",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "db:init": "wrangler d1 execute oshicard-db --file=./schema.sql --local",
    "db:init:remote": "wrangler d1 execute oshicard-db --file=./schema.sql --remote --env dev",
    "db:init:prod": "wrangler d1 execute oshicard-db-prod --file=./schema.sql --remote"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LarveyOfficial/oshicardapi.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/LarveyOfficial/oshicardapi/issues"
  },
  "homepage": "https://github.com/LarveyOfficial/oshicardapi#readme",
  "dependencies": {
    "cheerio": "^1.2.0",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260412.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.1"
  }
}
